{
  "rules": {
    ".read": true,
    ".write": false,

    "live": {
      ".read": true,
      ".write": "auth != null && auth.token.email_verified === true && auth.token.email === 'kubakristan@gmail.com'"
    },

    "contestants": {
      ".read": true,
      ".write": "auth != null && auth.token.email_verified === true && auth.token.email === 'kubakristan@gmail.com'"
    },

    "judges": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email_verified === true && auth.token.email === 'kubakristan@gmail.com'"
    },

    "judgeSessions": {
      ".read": "auth != null && (auth.token.email_verified === true || auth.uid != null)",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid && newData.child('judgeId').isString() && newData.child('judgeId').val().length > 0",
        ".validate": "newData.hasChildren(['judgeId', 'createdAt'])"
      }
    },

    "config": {
      ".read": true,
      ".write": "auth != null && auth.token.email_verified === true && auth.token.email === 'kubakristan@gmail.com'"
    },

    "scores": {
      ".read": true,
      ".write": true,
      "$contestantId": {
        ".read": true,
        ".write": true,
        "$roundId": {
          ".read": true,
          ".write": true,
          "$judgeId": {
            ".read": true,
            ".write": "(auth != null && root.child('judgeSessions').child(auth.uid).child('judgeId').val() === $judgeId) || (auth != null && auth.token.email_verified === true && auth.token.email === 'kubakristan@gmail.com') || (auth != null && root.child('judges').child($judgeId).child('name').val().toLowerCase() === 'admin')",
            ".validate": "newData.exists() ? ((newData.child('points').isNumber() || !newData.hasChild('points')) && (newData.child('overallFeel').isNumber() || !newData.hasChild('overallFeel'))) : true"
          }
        }
      }
    }
  }
}
